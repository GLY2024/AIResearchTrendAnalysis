{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ARTA",
  "version": "0.1.0",
  "identifier": "com.arta.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build-only"
  },
  "app": {
    "windows": [
      {
        "title": "ARTA - AI Research Trend Analysis",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/arta-backend"
    ]
  }
}
